generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                    String            @id @default(cuid())
  name                  String
  slug                  String            @unique
  domain                String?           @unique
  status                TenantStatus      @default(ACTIVE)
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  aiEnabled             Boolean           @default(false)
  monitoringEnabled     Boolean           @default(false)
  subscriptionTier      SubscriptionTier  @default(BASIC)
  telegramEnabled       Boolean           @default(false)
  actionFocus           String?
  foundingYear          Int?
  instagramHandle       String?
  lastPaymentAt         DateTime?
  launchProgress        Int               @default(0)
  launchStatus          LaunchStatus      @default(DRAFT)
  launchedAt            DateTime?
  monthlyFee            Decimal?          @db.Decimal(10, 2)
  newsletterEnabled     Boolean           @default(false)
  paymentStatus         String?           @default("pending")
  reviewBotEnabled      Boolean           @default(false)
  serviceRadius         Int?
  slogan                String?
  styleDirection        String?
  targetKeywords        String?
  toneOfVoice           String?
  topServices           String?
  usp                   String?
  whiteLabelEnabled     Boolean           @default(false)
  maintenanceModeEnabled Boolean           @default(false)
  workshopsEnabled      Boolean           @default(false)
  contactFormEnabled    Boolean           @default(false)
  setupPaid             Boolean         @default(false)
  blogPosts             BlogPost[]
  bookings              Booking[]
  employees             Employee[]
  inventory             InventoryItem[]
  invoices              Invoice[]
  knowledgeBase         KnowledgeBase[]
  payments              Payment[]
  reviews               Review[]
  socialConnections     SocialConnection[]
  services              Service[]
  systemLogs            SystemLog[]
  settings              TenantSettings?
  users                 User[]
  contactRequests       ContactRequest[]
  courses               Course[]

  @@index([status])
  @@index([subscriptionTier])
  @@index([launchStatus])
}

model TenantSettings {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  primaryColor      String   @default("#D4AF37")
  logoUrl           String?
  logoAlt           String?
  mobileHeroUrl     String?
  mobileHeroAlt     String?
  businessName      String
  businessAddress   String?
  businessPhone     String?
  businessEmail     String
  telegramUrl       String?
  instagramUrl      String?
  facebookUrl       String?
  linkedinUrl       String?
  tiktokUrl         String?
  twitterUrl        String?
  
  legalName         String?
  legalRepresentedBy String?
  vatId             String?
  courtRegister     String?

  impressum         String?
  datenschutz       String?
  openingHours      String?
  seoTitle          String?
  seoDescription    String?
  seoKeywords       String?
  ogImage           String?
  ogImageAlt        String?
  ogTitle           String?
  ogDescription     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  landingPageConfig String?
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id                String          @id @default(cuid())
  email             String
  passwordHash      String?
  name              String
  phone             String?
  customerStatus    CustomerStatus?
  role              UserRole        @default(CUSTOMER)
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  lastActiveAt      DateTime?
  bookings          Booking[]
  invoices          Invoice[]
  tenant            Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([role])
}

enum CustomerStatus {
  NEW
  REGULAR
  VIP
}

model Service {
  id          String            @id @default(cuid())
  tenantId    String
  name        String
  slug        String?
  description String?
  duration    Int
  price       Decimal           @db.Decimal(10, 2)
  salePrice   Decimal?          @db.Decimal(10, 2)
  category    String?
  imageUrl    String?
  legacyImages String[]          @default([]) @map("images")
  imageAlt    String?
  isActive    Boolean           @default(true)
  longDescription String?
  benefits      String[]        @default([])
  faqs          Json?           @default("[]")
  metaTitle     String?
  metaDescription String?
  sortOrder     Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  bookings    Booking[]
  legacyBookingLinks LegacyBookingToService[]
  employees   EmployeeService[]
  serviceImages ServiceImage[]
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model ServiceImage {
  id        String   @id @default(cuid())
  serviceId String
  imageUrl  String
  imageAlt  String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([serviceId, sortOrder])
}

model Employee {
  id           String                 @id @default(cuid())
  tenantId     String
  name         String
  email        String?
  phone        String?
  avatarUrl    String?
  bio          String?
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  bookings     Booking[]
  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  availability EmployeeAvailability[]
  services     EmployeeService[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model EmployeeService {
  employeeId String
  serviceId  String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([employeeId, serviceId])
}

model EmployeeAvailability {
  id          String   @id @default(cuid())
  employeeId  String
  dayOfWeek   Int
  startTime   String
  endTime     String
  isAvailable Boolean  @default(true)
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, dayOfWeek])
  @@index([employeeId])
}

model Booking {
  id           String        @id @default(cuid())
  tenantId     String
  userId       String
  serviceId    String?
  employeeId   String
  startTime    DateTime
  endTime      DateTime
  status       BookingStatus @default(PENDING)
  notes        String?
  paymentId    String?
  reminderSent Boolean       @default(false)
  confirmedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  employee     Employee      @relation(fields: [employeeId], references: [id])
  legacyServiceLinks LegacyBookingToService[]
  payment      Payment?      @relation(fields: [paymentId], references: [id])
  service      Service?      @relation(fields: [serviceId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id])
  invoices     Invoice[]

  @@index([tenantId, employeeId, startTime, endTime])
  @@index([tenantId, status])
  @@index([tenantId, userId])
  @@index([startTime])
}

model LegacyBookingToService {
  bookingId String @map("A")
  serviceId String @map("B")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([bookingId, serviceId])
  @@map("_BookingToService")
}

model Payment {
  id               String        @id @default(cuid())
  tenantId         String
  stripePaymentId  String?       @unique
  stripeCustomerId String?
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("EUR")
  status           PaymentStatus @default(PENDING)
  paymentType      PaymentType   @default(FULL)
  category         InvoiceType   @default(CLIENT_SERVICES)
  receiptUrl       String?
  refundedAt       DateTime?
  refundAmount     Decimal?      @db.Decimal(10, 2)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  bookings         Booking[]
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([status, createdAt])
}

model KnowledgeBase {
  id        String   @id @default(cuid())
  tenantId  String
  question  String
  answer    String
  category  String?
  keywords  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   String?
  newData   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
  @@index([entity, entityId])
}

model ExternalWebsite {
  id           String        @id @default(cuid())
  name         String
  url          String        @unique
  clientName   String?
  clientEmail  String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  seoSnapshots SeoSnapshot[]

  @@index([isActive])
}

model SeoSnapshot {
  id                 String           @id @default(cuid())
  tenantId           String?
  externalWebsiteId  String?
  url                String
  performanceScore   Int
  accessibilityScore Int
  seoScore           Int
  bestPracticesScore Int
  loadTimeMs         Int?
  sslValid           Boolean          @default(true)
  sslExpiresAt       DateTime?
  isOnline           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  externalWebsite    ExternalWebsite? @relation(fields: [externalWebsiteId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([externalWebsiteId])
  @@index([createdAt])
}

model SocialPost {
  id          String    @id @default(cuid())
  tenantId    String?
  platform    String
  content     String
  imageUrl    String?
  scheduledAt DateTime
  publishedAt DateTime?
  status      String    @default("DRAFT")
  metrics     String?
  errorLog    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([status])
  @@index([scheduledAt])
}

model SocialConnection {
  id           String   @id @default(cuid())
  tenantId      String
  platform      String
  accountId     String?
  accountName   String?
  pageId        String?
  pageName      String?
  igBusinessId  String?
  accessToken   String?
  refreshToken  String?
  tokenExpiresAt DateTime?
  scopes        String?
  status        String   @default("DISCONNECTED")
  lastSyncAt    DateTime?
  metadata      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, platform])
  @@index([tenantId])
  @@index([platform])
  @@index([status])
}

model TelegramConfig {
  id              String   @id @default(cuid())
  chatId          String   @unique
  botToken        String
  isActive        Boolean  @default(true)
  alertOnDown     Boolean  @default(true)
  alertOnLowScore Boolean  @default(true)
  alertThreshold  Int      @default(50)
  dailyReport     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model NavAnalytics {
  id        String   @id @default(cuid())
  path      String   @unique
  clicks    Int      @default(0)
  updatedAt DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(cuid())
  tenantId  String?
  level     String
  category  String
  action    String
  problem   String?
  solution  String?
  status    String   @default("pending")
  metadata  String?
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([level])
  @@index([category])
  @@index([status])
  @@index([createdAt])
}

model BlogPost {
  id          String    @id @default(cuid())
  tenantId    String?
  title       String
  slug        String    @unique
  content     String
  excerpt     String?
  keywords    String?
  status      String    @default("DRAFT")
  author      String?   @default("AI")
  coverImage  String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model Review {
  id        String    @id @default(cuid())
  tenantId  String?
  source    String
  rating    Int
  author    String
  content   String
  status    String    @default("PENDING")
  aiDraft   String?
  sentiment String?
  repliedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tenant    Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([rating])
}

model InventoryItem {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  sku          String?
  category     String?
  currentStock Int       @default(0)
  minStock     Int       @default(5)
  unit         String    @default("pcs")
  costPerUnit  Decimal?  @db.Decimal(10, 2)
  supplier     String?
  location     String?
  status       String    @default("IN_STOCK")
  lastRestock  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model Invoice {
  id            String      @id @default(cuid())
  tenantId      String
  bookingId     String?
  userId        String?
  invoiceNumber String
  amount        Decimal     @db.Decimal(10, 2)
  status        String      @default("PENDING")
  type          InvoiceType @default(CLIENT_SERVICES)
  pdfUrl        String?
  items         String?
  dueDate       DateTime
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  booking       Booking?    @relation(fields: [bookingId], references: [id])
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User?       @relation(fields: [userId], references: [id])

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([status])
  @@index([bookingId])
  @@index([type])
}

enum InvoiceType {
  PLATFORM_FEES    // User -> Tenant (Subscription, Setup, etc.)
  CLIENT_SERVICES  // Tenant -> Customer (Haircut, Nails, etc.)
}

model SystemConfig {
  id                 String   @id @default(cuid())
  openaiKey          String?
  anthropicKey       String?
  geminiKey          String?
  perplexityKey      String?
  groqKey            String?
  activeModel        String   @default("gemini-1.5-flash")
  factoryModeEnabled Boolean  @default(true)
  isLocked           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  stripeSecretKey    String?
  vercelToken        String?
  analysisModel      String   @default("gemini-2.0-flash")
  contentModel       String   @default("llama-3.3-70b-versatile")
  jarvisModel        String   @default("gemini-2.0-flash")
  n8nUrl             String?
  n8nApiKey          String?
}

enum SubscriptionTier {
  BASIC
  PRO
  ENTERPRISE
  CUSTOM
  LEGACY
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  PENDING
  DELETED
}

enum UserRole {
  MASTER_ADMIN
  SALON_OWNER
  EMPLOYEE
  CUSTOMER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentType {
  DEPOSIT
  FULL
  SALON
}

enum LaunchStatus {
  DRAFT
  GENERATING
  REVIEW
  LIVE
  PAUSED
}

model AutomationWorkflow {
  id          String         @id @default(cuid())
  name        String
  description String?
  isActive    Boolean        @default(true)
  triggerType String         // e.g. "PAYMENT_RECEIVED", "NEW_TENANT"
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  nodes       WorkflowNode[]
  logs        WorkflowLog[]
}

model WorkflowNode {
  id           String             @id @default(cuid())
  workflowId   String
  type         String             // "ACTION"
  actionType   String             // "SEND_EMAIL", "UNLOCK_FEATURE", "TELEGRAM"
  config       String?            // JSON Config for the action
  order        Int
  workflow     AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model WorkflowLog {
  id           String             @id @default(cuid())
  workflowId   String
  status       String             // "SUCCESS", "FAILED"
  message      String?
  startedAt    DateTime           @default(now())
  completedAt  DateTime?
  workflow     AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

// ============================================
// CONTACT REQUESTS (Terminanfragen ohne Login)
// ============================================
model ContactRequest {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String
  phone     String?
  service   String?
  message   String?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

// ============================================
// COURSES / WORKSHOPS
// ============================================
model Course {
  id          String             @id @default(cuid())
  tenantId    String
  title       String
  description String?
  category    String?
  startDate   DateTime?
  timeText    String?
  price       Decimal            @db.Decimal(10, 2)
  deposit     Decimal?           @db.Decimal(10, 2)
  maxSpots    Int                @default(6)
  includes    String?
  imageUrl    String?
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollments CourseEnrollment[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model CourseEnrollment {
  id        String   @id @default(cuid())
  courseId   String
  name      String
  email     String
  phone     String?
  status    String   @default("PENDING")
  paid      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
}
